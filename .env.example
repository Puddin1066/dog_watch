# =============================================================================
# v2 — HTTP snapshot ingest + ROI motion (PRD v2; works without camera RTSP)
# =============================================================================
SNAPSHOT_URL=
SNAPSHOT_HTTP_USER=
SNAPSHOT_HTTP_PASSWORD=
SNAPSHOT_TLS_VERIFY=false

# Optional Home Assistant pre-gate
# HA_BASE_URL=http://homeassistant.local:8123
# HA_TOKEN=
# HA_MOTION_ENTITY_ID=binary_sensor.lawn_motion

# ROI: prefer config/roi.json or set ROI_POLYGON
# ROI_POLYGON=0.1,0.55,0.9,0.55,0.95,0.95,0.05,0.95

MOTION_THRESHOLD=0.02
MIN_CONSECUTIVE_HITS=3
INTENSITY_DELTA=25

ALERT_COOLDOWN_SECONDS=180
POLL_INTERVAL_SECONDS=2
IMESSAGE_TARGET=+15555555555
ALERT_MESSAGE=Possible dog event detected on front lawn.
DEDUPE_ENABLED=true

SNAPSHOT_DIR=./storage/snapshots
LOG_FILE=./logs/alerts.log

MOCK_MODE=true
IMESSAGE_DRY_RUN=true

# =============================================================================
# Phase 2 — Frigate + RTSP (Reolink E1 Pro on LAN, or Docker MOCK RTSP below)
# =============================================================================
# For Frigate UI/API (set after first docker compose; Frigate creates bootstrap user)
FRIGATE_BASE_URL=https://localhost:8971
FRIGATE_USERNAME=admin
FRIGATE_PASSWORD=change_me_after_first_login
FRIGATE_TLS_VERIFY=false

# Watcher / Frigate camera name + zone (must match config/frigate.yml)
CAMERA_NAME=lawn_cam
TARGET_ZONE=front_lawn
MIN_EVENT_DURATION_SECONDS=5

# --- Option A: MOCK RTSP (synthetic test pattern — NOT a real camera) ----------
# Start stack: docker compose --profile mock-rtsp up -d
# MediaMTX publishes rtsp://mock_rtsp:8554/e1pro-mock on the compose network.
CAMERA_USERNAME=admin
CAMERA_RTSP_PASSWORD=mock
CAMERA_IP=mock_rtsp
CAMERA_RTSP_PORT=8554
CAMERA_RTSP_PATH=e1pro-mock

# --- Option B: Real Reolink E1 Pro on LAN (replace Option A values) ------------
# CAMERA_USERNAME=admin
# CAMERA_RTSP_PASSWORD=url_encoded_password
# CAMERA_IP=192.168.1.50
# CAMERA_RTSP_PORT=554
# CAMERA_RTSP_PATH=h264Preview_01_main

# MOCK_MODE=true on event_watcher.py means: mock Frigate *HTTP* API (no live Frigate).
# For full integration tests, set MOCK_MODE=false and use real Frigate + Option A or B RTSP above.
